  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 23d4ccac6b075644f8b66a21be3e8082, type: 3}
  m_Name: 
  m_EditorClassIdentifier: '::'
  speechBubblePrefab: {fileID: 37524668728497161, guid: 5e1f82bd5852be547a763cad474f3776, type: 3}
  guiCanvas: {fileID: 1817950265}
  sceneTransition: {fileID: 1428175108}
  steps:
  - message: Agent... can you hear me?
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Good... Now listen carefully.
    triggerType: 0
    requiredStationIndex: 1
    requiredObjectId: 
    customEventId: 
  - message: You are standing in a cellar that does not officially exist, somewhere
      in a country that will never be named.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'The damp walls around you? Once used to store wine. '
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Now repurposed as a training ground for operatives of our Directorate.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You work for us.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "From this moment on, you will be embedded inside the most secure building
      in the world \u2014 the Pentagon."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Officially, you are nothing more than a fast food cashier at a chain
      called Secret Munchies.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: An apron. A name tag. A forgettable face.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Unofficially... you are our ears.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will man the cash register.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will pack the orders.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will place the bags neatly on the counter.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will smile.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: And while high-ranking officials fumble for their credit cards, they
      will talk.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Carelessly. Casually. They will assume you are invisible.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You are not invisible.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will memorize what they say.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Then you will slip away to a restricted back room.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: And you will transmit what you heard via Morse code back to HQ.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: That is your mission.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Now... let us begin your training.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'Look in front of you. The first station: the cash register terminal.'
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'I want you to place a test order in the application on the computer. '
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'Open the application on the left. '
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Select any item. Create the order.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: open_order_maker
  - message: Good.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: create_order
  - message: The food is being prepared now.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Now you will notice a form application next to the ordering system.
      Open it.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "It is labeled \u201CCompliance Assessment.\u201D "
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: open_notepad
  - message: Ignore the title. It is camouflage.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Each horizontal line you see represents a customer.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'Each line contains four small squares: A, B, C, and D.'
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: These squares represent types of intelligence.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "A \u2014 Aliens. Unidentified crafts. Off-world contact."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "B \u2014 BlackOps. Covert missions. Classified task forces."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "C \u2014 Politics. Internal debates. Elections. Policy shifts."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "D \u2014 War. Deployments. Weapons movement. Strategic planning."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "When a \u201Ccustomer\u201D speaks and reveals valuable information... "
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: you will mentally categorize what you hear and tick the corresponding
      squares on that line.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Example...
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "If a general casually mentions increased naval presence near disputed
      waters \u2014 that is D. War."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "If two analysts whisper about a denied operation in a foreign state
      \u2014 that is B. BlackOps."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "If someone references a senate vote tied to defense funding \u2014
      that is C. Politics."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "If, by some miracle, someone mutters about recovered non-human technology
      \u2014 that is A. Aliens."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: 'Some intel overlaps. BlackOps related to a war scenario? That could
      be B and D. '
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Political funding for secret aerospace projects? C and A.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "However\u2026 not all combinations are valid. Certain pairings do not
      occur together within our classification system."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You will consult the Spy Handbook at the third station for approved
      combinations.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: For now, practice ticking squares.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Choose a line. Imagine a customer. Mark the squares according to the
      intel type.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Good.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: square_ticked
  - message: Now press the button to print the papers.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You may print multiple sheets. In the field, redundancy keeps you alive.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: sheet_printed
  - message: 'These printed forms are your personal notes. Nothing more. '
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "After you transmit a line\u2019s intelligence, you may cross it out
      with a pen. That is for you alone."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Now... Move to your right.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: You are now at the food dispenser station.
    triggerType: 1
    requiredStationIndex: 1
    requiredObjectId: 
    customEventId: 
  - message: Take the prepared food items. Place them into the bag.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Close the bag and pick it up.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: item_added_to_bag
  - message: Now place it on the left side of the dispenser.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: on_bag_picked
  - message: In the Pentagon, that left side will be the public counter. Customers
      will step forward and retrieve their order.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: on_bag_dropped
  - message: Move right.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: This is the Spy Handbook.
    triggerType: 1
    requiredStationIndex: 2
    requiredObjectId: 
    customEventId: 
  - message: Open it.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Inside you will see the approved combinations of A, B, C, and D and
      the Morse sequences assigned to each.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: spy_book
  - message: When you receive intel and mark your form, you will reference this handbook
      to determine which Morse pattern must be sent.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: "You also have your printed notes. After transmitting a line\u2019s
      intelligence, cross it out."
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: The order doesn't matter. Just make sure you send us EVERYTHING.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Otherwise... We will have to... terminate your contract.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Now... Move right to the last station.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: This is the Morse code machine.
    triggerType: 1
    requiredStationIndex: 3
    requiredObjectId: 
    customEventId: 
  - message: To complete this training debrief, you will send a simple message.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: SOS
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Three dots. Three dashes. Three dots.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Tap it out.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Good.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: morse_code_tapped
  - message: Now tear the paper off.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: That tearing sound? That is confirmation. The message has been sent.
    triggerType: 3
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: morse_code_sent
  - message: 'Remember this cellar. Remember these four stations: register, dispenser,
      handbook, transmitter.'
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Soon, the concrete dark walls around you will be replaced by polished
      corridors and armed security.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: But your task will remain the same.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Smile. Listen. Categorize. Transmit.
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
  - message: Welcome to Secret Munchies, Agent...
    triggerType: 0
    requiredStationIndex: 0
    requiredObjectId: 
    customEventId: 
