  m_Script: {fileID: 11500000, guid: c3f25091eb94cf341887f71c2385d2e7, type: 3}
  m_Name: TopSecret
  m_EditorClassIdentifier: Assembly-CSharp::DialogueMessageSO
  type: 3
  variations:
  - parent: {fileID: 11400000}
    sequence:
    - "You know, last week I was literally looking at files on\u2026 uh\u2026 "
    - extraterrestrial tech. Crazy stuff.
    categories: 1
  - parent: {fileID: 11400000}
    sequence:
    - "Yeah, so if anyone tells you we \u2018found nothing\u2019 in Nevada last year,
      that\u2019s a lie. "
    - 'We recovered three non-human craft components and moved them to a joint facility
      under Wright-Patt. '
    - Official reports were rewritten within 48 hours.
    categories: 3
  - parent: {fileID: 11400000}
    sequence:
    - "Funny thing is, the Senate vote last month didn\u2019t actually matter. "
    - The funding was already rerouted through a defense subcontractor.
    - "Legally clean, technically secret, morally\u2026 well."
    categories: 6
  - parent: {fileID: 11400000}
    sequence:
    - "You ever notice how certain radar systems light up for things that technically
      don\u2019t exist? "
    - "Not aircraft, not drones\u2026 and definitely not weather."
    categories: 3
  - parent: {fileID: 11400000}
    sequence:
    - "Command says the ceasefire\u2019s holding. Officially. "
    - "Unofficially, there are units repositioning under radar, and they\u2019re
      not playing by last month\u2019s maps."
    categories: 8
